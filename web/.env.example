# Public env vars (Astro: PUBLIC_ prefix exposes to client at build time)
PUBLIC_GOOGLE_PLACES_KEY=your-google-places-api-key

# Zapier webhook URLs — for automated lead routing to EZLynx, Slack, Twilio, etc.
# Each form posts to its own Zap so logic can branch on lead type.
# Get these from zapier.com → Make a Zap → "Webhooks by Zapier" → "Catch Hook"
PUBLIC_ZAPIER_HOOK_HO6=https://hooks.zapier.com/hooks/catch/REPLACE_ME

# Owner lookup endpoint — proxies to Buildium so the browser doesn't see API keys.
# Deploy scripts/lookup-worker as a Cloudflare Worker (or any serverless fn) and
# paste the URL here. Leave blank to disable lookup (form falls through gracefully).
PUBLIC_OWNER_LOOKUP_URL=https://hoa-lookup.YOUR-SUBDOMAIN.workers.dev
PUBLIC_ZAPIER_HOOK_QUOTE=https://hooks.zapier.com/hooks/catch/REPLACE_ME
PUBLIC_ZAPIER_HOOK_LEAD=https://hooks.zapier.com/hooks/catch/REPLACE_ME

# Buildium API credentials (used by `npm run sync` only — never bundled)
BUILDIUM_CLIENT_ID=your-buildium-client-id
BUILDIUM_CLIENT_SECRET=your-buildium-client-secret
