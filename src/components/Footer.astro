---
import { PHONE, PHONE_HREF, EMAIL, EMAIL_HREF, ADDRESS_LINE1, ADDRESS_LINE2, SOCIAL } from "../constants";
---

<footer class="site-footer">
  <div class="site-footer__main">
    <a href="/" class="site-footer__logo-link">
      <img src="/logo.png" alt="HOA Insurance Agency" class="site-footer__logo" />
    </a>
    <p class="site-footer__addr">{ADDRESS_LINE1}<br />{ADDRESS_LINE2}</p>
    <p class="site-footer__contact">
      <a href={EMAIL_HREF}>{EMAIL}</a>
      <span class="site-footer__dot">&middot;</span>
      <a href={PHONE_HREF}>{PHONE}</a>
    </p>
    <div class="site-footer__social">
      <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href={SOCIAL.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
      </a>
      <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
      </a>
    </div>
  </div>
  <div class="site-footer__bottom">
    <a href="/privacy-policy">Privacy Policy</a>
    <span class="site-footer__dot">&middot;</span>
    <a href="/terms-of-service">Terms of Service</a>
    <span class="site-footer__dot">&middot;</span>
    <span>&copy; {new Date().getFullYear()} HOA Insurance Agency</span>
  </div>
</footer>

<style>
  .site-footer {
    background: #1a365d;
    color: rgba(255, 255, 255, 0.7);
    width: 100%;
    box-sizing: border-box;
  }

  .site-footer__main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 24px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }

  .site-footer__logo {
    display: block;
    height: 44px;
    width: auto;
    filter: brightness(0) invert(1);
    margin-bottom: 8px;
  }

  .site-footer__addr {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
  }

  .site-footer__contact {
    font-size: 14px;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .site-footer__contact a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    transition: color 0.2s;
  }

  .site-footer__contact a:hover {
    color: #fff;
  }

  .site-footer__dot {
    color: rgba(255, 255, 255, 0.25);
  }

  .site-footer__social {
    display: flex;
    gap: 20px;
    margin-top: 8px;
  }

  .site-footer__social a {
    color: rgba(255, 255, 255, 0.45);
    transition: color 0.2s;
  }

  .site-footer__social a:hover {
    color: #fff;
  }

  .site-footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    max-width: 1200px;
    margin: 0 auto;
    padding: 18px 24px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .site-footer__bottom a {
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    transition: color 0.2s;
  }

  .site-footer__bottom a:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .site-footer__main {
      padding: 48px 20px 32px;
    }
  }
</style>
